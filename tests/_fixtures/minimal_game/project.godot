; Minimal playmode fixture for tasklist 17 runtime.* headless tests.

config_version=5

[application]

config/name="terravolt-minimal-game"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.0")

[autoload]

TerravoltRuntimeBridge="res://autoloads/runtime_bridge.gd"

[terravolt_mcp]

runtime/port=6506

[rendering]

renderer/rendering_method="gl_compatibility"
