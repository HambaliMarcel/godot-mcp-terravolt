# Godot
.import/
*.translation
.mono/
data_*/
xcuserdata/

# OS / editors
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Logs & temp
*.log
*.tmp
~*

# Node / Omni
node_modules/

# GitNexus index + parse artifacts (npm run intel:gitnexus)
.gitnexus/

# Local Claude IDE skills cache / copies (skills live globally or in docs — not vendor here)
.claude/

# Graphify (optional: commit graphify-out/ for team — ignore volatile files per upstream README)
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/cache/

# Third-party reference clones at repo root only (see README — not vendored in git).
# Use leading slash so `docs/references/` (tracked docs) is not ignored.
/references/

# Leftover from git filter-branch (if present)
.git-rewrite/

# Build output
dist/

# Linear roadmap bulk import resume ledger (personal machine)
.linear_children_import_done.tsv

# Local Godot env profile (produced by `npm run env:godot`)
.terravolt/

# Ephemeral MCP manifest previews (generator: tools/_emit_manifest.py)
tools/_scratch_manifest.json

# Staged addon for `tests/_fixtures/with-addon` parse-check (created on demand)
tests/_fixtures/with-addon/addons/
tests/_fixtures/with-addon/.godot/
tests/_fixtures/empty/.godot/

# Linear import scratch (payload chunks — regenerate locally; never vendor)
tools/.linear-batch/

# Regenerated epic markdown previews derived from docs/tasklist
tools/linear_epic_preview/

# Local secrets / overrides (prefer examples committed as *.example)
.env
.env.*
!.env.example

