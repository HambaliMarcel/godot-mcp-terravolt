{
  "name": "godot-mcp-terravolt",
  "version": "0.1.0",
  "private": true,
  "description": "Godot MCP (TerraVolt) — omni-protocol tooling: Graphify + GitNexus",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "intel:graphs": "node scripts/regen-graphs.mjs",
    "intel:gitnexus": "node scripts/run-gitnexus.mjs",
    "intel:graphify": "py -3 -m graphify update .",
    "intel:graphify:cluster": "py -3 -m graphify cluster-only .",
    "omni:intel": "npm run intel:gitnexus && npm run intel:graphs && npm run intel:graphify"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.0.0",
    "gitnexus": "^1.6.4",
    "madge": "^8.0.0"
  }
}
